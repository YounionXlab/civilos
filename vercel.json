{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/.next",
  "rewrites": [
    {
      "source": "/world",
      "destination": "/api/index.py"
    },
    {
      "source": "/agents",
      "destination": "/api/index.py"
    },
    {
      "source": "/history",
      "destination": "/api/index.py"
    },
    {
      "source": "/tick",
      "destination": "/api/index.py"
    }
  ]
}
